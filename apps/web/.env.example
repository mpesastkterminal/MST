# MST web renderer environment

# Purpose: API base URL used by the Next.js renderer.
# Example: http://localhost:4000
# Local: required.
# Production: set to the Railway API public URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Purpose: Supabase project URL for browser auth.
# Example: https://abcxyz.supabase.co
# Local: required.
# Production: required.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Purpose: Supabase anon key for browser auth.
# Example: eyJhbGciOi...
# Local: required.
# Production: required; safe to expose as Supabase anon key, not service key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
