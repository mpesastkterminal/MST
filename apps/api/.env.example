# MST API environment

# Purpose: runtime mode used for production safety checks.
# Example: development
# Local: optional; usually set to development by tooling.
# Production: required; set to production.
NODE_ENV=development

# Purpose: HTTP port used by Express.
# Example: 4000
# Local: optional; defaults to 4000.
# Production: Railway injects PORT automatically; do not hardcode it.
PORT=4000

# Purpose: allowed browser origin for CORS.
# Example: http://localhost:3000
# Local: required for web development.
# Production: set to the deployed web/desktop renderer origin if hosted.
WEB_ORIGIN=http://localhost:3000

# Purpose: Supabase project URL used by auth and database clients.
# Example: https://abcxyz.supabase.co
# Local: required.
# Production: required.
SUPABASE_URL=https://your-project.supabase.co

# Purpose: Supabase anon key used to validate user-scoped requests.
# Example: eyJhbGciOi...
# Local: required.
# Production: required.
SUPABASE_ANON_KEY=your-supabase-anon-key

# Purpose: Supabase service role key for backend-only writes after API permission checks.
# Example: eyJhbGciOi...
# Local: required for onboarding, lifecycle, sessions, terminals, dashboard, reporting, audit, and STK flows.
# Production: required; store only in Railway variables.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Purpose: AES-256-GCM key for encrypted M-Pesa credentials.
# Example generation: node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))"
# Local: required before saving credentials.
# Production: required; keep stable or credentials cannot be decrypted.
MST_CREDENTIAL_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# Purpose: public HTTPS API URL Safaricom can call for STK callbacks.
# Example: https://mst-api-production.up.railway.app
# Local: required for live Daraja callbacks; use an HTTPS tunnel for sandbox callback tests.
# Production: required and must be publicly reachable over HTTPS.
MST_PUBLIC_API_URL=https://your-railway-api-domain.example.com
