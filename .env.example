# MST master environment template

## API / Railway

# purpose: Node runtime mode.
# example: production
# required: true
NODE_ENV=production

# purpose: Express listen port. Railway injects this automatically.
# example: 4000
# required: false
PORT=4000

# purpose: Browser origins allowed to call the API, comma-separated.
# example: http://localhost:3000,https://mst.up.railway.app
# required: true
WEB_ORIGIN=http://localhost:3000,https://mst.up.railway.app

# purpose: Supabase project URL for backend auth/database clients.
# example: https://your-project.supabase.co
# required: true
SUPABASE_URL=https://your-project.supabase.co

# purpose: Supabase anon key for validating user-scoped auth.
# example: eyJhbGciOi...
# required: true
SUPABASE_ANON_KEY=your-supabase-anon-key

# purpose: Supabase service role key for backend-only admin operations.
# example: eyJhbGciOi...
# required: true
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# purpose: AES-256-GCM key for encrypted M-Pesa branch credentials.
# example: base64:replace-with-32-byte-key
# required: true
MST_CREDENTIAL_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# purpose: Public API URL used to generate M-Pesa callback URLs.
# example: https://mst-api.up.railway.app
# required: true
MST_API_PUBLIC_URL=https://mst-api.up.railway.app

## Web / Next.js Renderer

# purpose: API base URL used by the browser renderer.
# example: https://mst-api.up.railway.app
# required: true
NEXT_PUBLIC_API_URL=https://mst-api.up.railway.app

# purpose: Supabase project URL used by browser auth.
# example: https://your-project.supabase.co
# required: true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# purpose: Supabase anon key used by browser auth.
# example: eyJhbGciOi...
# required: true
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

## Desktop / Electron

# purpose: Web renderer URL loaded by Electron. This is not the API URL.
# example: http://localhost:3000
# required: false
MST_WEB_URL=http://localhost:3000
